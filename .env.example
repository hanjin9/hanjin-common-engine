# ============================================================
# 한진 공통 엔진 (hanjin-common-engine) 환경변수 설정
# ============================================================
# 이 파일을 복사해서 .env 파일로 만드세요:
#   cp .env.example .env
# ============================================================

# ─── 🔴 CORE ENGINE (필수) ──────────────────────────────────

# 서버 설정
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# 데이터베이스 (TiDB / MySQL 호환)
# TiDB Cloud: https://tidbcloud.com
DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/DB_NAME?ssl={"rejectUnauthorized":true}

# Manus OAuth 인증 (필수)
# Manus 대시보드에서 발급: https://manus.im
OAUTH_SERVER_URL=https://auth.manus.im
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_manus_api_key_here
VITE_APP_ID=your_manus_app_id_here

# JWT (임의의 긴 랜덤 문자열)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# 관리자 계정 (Manus OpenID)
OWNER_OPEN_ID=your_manus_open_id_here

# ─── 💳 Stripe 결제 (핵심 기능) ────────────────────────────
# Stripe 대시보드: https://dashboard.stripe.com
#
# ⚠️  테스트 시: sk_test_... 키 사용 (실제 결제 없음)
# ⚠️  운영 시:   sk_live_... 키 사용 (실제 결제 발생)

# Stripe API 키 (대시보드 > Developers > API Keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook 서명 시크릿
# 설정 방법: https://dashboard.stripe.com/webhooks
# 웹훅 URL: https://your-domain.com/api/stripe/webhook
# 수신 이벤트: checkout.session.completed, customer.subscription.*,  invoice.payment_*
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── 📧 이메일 알림 (선택 — 없으면 이메일 발송 비활성화) ──
# Resend: https://resend.com (무료 100건/일)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=한진 공통 엔진 <noreply@yourdomain.com>

# ─── 🟡 STANDARD MODULE (선택) ──────────────────────────────

# Redis (BullMQ 스케줄러 사용 시 필요)
# 없으면 스케줄러 비활성화
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentry 에러 모니터링 (선택)
# https://sentry.io
SENTRY_DSN=https://your_dsn@sentry.io/your_project_id

# ─── 🔵 GLWA EXTENSION (GLWA 프로젝트 전용) ─────────────────

# Google Fit / Google OAuth (GLWA 건강 추적 전용)
# https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_FIT_CLIENT_ID=your_google_fit_client_id
GOOGLE_FIT_CLIENT_SECRET=your_google_fit_client_secret

# Kakao OAuth (GLWA 소셜 로그인 전용)
# https://developers.kakao.com
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Supabase (일부 GLWA 기능 전용)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# 📋 최소 실행 체크리스트 (CORE만 사용 시)
# ============================================================
# □ DATABASE_URL       — TiDB 또는 MySQL 연결
# □ OAUTH_SERVER_URL   — Manus 인증 서버
# □ BUILT_IN_FORGE_API_KEY — Manus API
# □ STRIPE_SECRET_KEY  — Stripe (테스트 키로 시작)
# □ JWT_SECRET         — 임의 랜덤 문자열
# ============================================================
